exports[`ProgressPopup.0% 1`] = `"<div class="popup-overlay"><div class="popup-container"><div class="row popup-container__header popup-container__header__normal"><span class="progress-popup__title"></span></div><div class="row popup-container__body"><div class="columns large-12 popup-container__body__hasNoIcon"><div class="progress-popup__content"><div style="width:90%;height:10px;margin:15px auto;background:#CCD6DD;border-radius:5px"><div style="background:#18BE94;height:100%;width:0%;border-radius:inherit;transition:width 0.1s ease-in"></div></div></div></div></div><div class="row popup-container__footer"><div class="progress-popup__footer"></div></div></div></div>"`;

exports[`ProgressPopup.50% 1`] = `"<div class="popup-overlay"><div class="popup-container"><div class="row popup-container__header popup-container__header__normal"><span class="progress-popup__title">My Title</span></div><div class="row popup-container__body"><div class="columns large-12 popup-container__body__hasNoIcon"><div class="progress-popup__content"><div style="width:90%;height:10px;margin:15px auto;background:#CCD6DD;border-radius:5px"><div style="background:#18BE94;height:100%;width:100%;border-radius:inherit;transition:width 0.1s ease-in"></div></div></div></div></div><div class="row popup-container__footer"><div class="progress-popup__footer"></div></div></div></div>"`;

exports[`ProgressPopup.100% 1`] = `"<div class="popup-overlay"><div class="popup-container"><div class="row popup-container__header popup-container__header__normal"><span class="progress-popup__title"></span></div><div class="row popup-container__body"><div class="columns large-12 popup-container__body__hasNoIcon"><div class="progress-popup__content"><div style="width:90%;height:10px;margin:15px auto;background:#CCD6DD;border-radius:5px"><div style="background:#18BE94;height:100%;width:100%;border-radius:inherit;transition:width 0.1s ease-in"></div></div></div></div></div><div class="row popup-container__footer"><div class="progress-popup__footer"><button class="argo-button argo-button--base-o">Close</button></div></div></div></div>"`;
