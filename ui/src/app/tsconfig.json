{
    "compilerOptions": {
        "outDir": "./../../dist/app",
        "sourceMap": true,
        "noImplicitAny": true,
        "module": "esnext",
        "moduleResolution": "node",
        "target": "es2022",
        "jsx": "react",
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "noUnusedLocals": true,
        "declaration": false,
        "skipLibCheck": true,
        "types": [
            "jest",
            "node"
        ],
        "lib": [
            "es2022",
            "dom"
        ]
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
